              }
            }
          }
        },
        {
          "title": "Cart",
          "id": "commerce-cart",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/block/v1/block",
                "template": {
                  "name": "commerce-cart",
                  "model": "commerce-cart",
                  "key-value": true,
                  "start-shopping-url": "/",
                  "checkout-url": "/checkout",
                  "hide-heading": false,
                  "hide-attributes": false,
                  "enable-item-quantity-update": true,
                  "enable-item-remove": true,
                  "enable-estimate-shipping": true
